#!/usr/bin/env bash

set -euo pipefail

###############################################################################
# Configuration                                                                #
###############################################################################

# Script configuration
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly BACKUP_DIR="${SCRIPT_DIR}/backups"
readonly LOG_DIR="${SCRIPT_DIR}/logs"
readonly CONFIG_DIR="${SCRIPT_DIR}/config"

# Default settings
readonly DEFAULT_BACKUP=false
readonly DEFAULT_FORCE=false
readonly DEFAULT_DRY_RUN=false
readonly DEFAULT_VERBOSE=false
readonly DEFAULT_SILENT=false
readonly DEFAULT_NO_RESTART=false
readonly DEFAULT_NO_LOG=false
readonly DEFAULT_CONFIRMATION_TIMEOUT=30

# Logging configuration
readonly LOG_LEVEL_INFO=0
readonly LOG_LEVEL_WARN=1
readonly LOG_LEVEL_ERROR=2
readonly LOG_LEVEL_DEBUG=3
readonly DEFAULT_LOG_LEVEL=$LOG_LEVEL_INFO
readonly DEFAULT_LOG_MAX_SIZE=10M
readonly DEFAULT_LOG_ROTATE_COUNT=5

# Timeout settings (in seconds)
readonly COMMAND_TIMEOUT=30
readonly RESTART_TIMEOUT=5
readonly BACKUP_TIMEOUT=300
readonly LOCK_TIMEOUT=60
readonly SUDO_TIMEOUT=300

# Error codes
readonly E_SUCCESS=0
readonly E_GENERAL=1
readonly E_USAGE=2
readonly E_NO_ROOT=3
readonly E_MODULE_NOT_FOUND=4
readonly E_BACKUP_FAILED=5
readonly E_RESTORE_FAILED=6
readonly E_LOCK_FAILED=7
readonly SCRIPT_NAME=$(basename "$0")
readonly VERSION="1.0.0"

# Source required libraries
source "$SCRIPT_DIR/lib/utils.sh"
source "$SCRIPT_DIR/lib/modules.sh"
source "$SCRIPT_DIR/lib/logging.sh"

# Available modules
declare -A AVAILABLE_MODULES=(
    ["backup"]="Create backup of current settings"
    ["finder"]="Finder settings"
    ["dock"]="Dock settings"
    ["safari"]="Safari settings"
    ["mail"]="Mail.app settings"
    ["terminal"]="Terminal settings"
    ["system"]="System settings"
    ["input"]="Input device settings"
    ["security"]="Security settings"
    ["cleanup"]="System cleanup operations"
)

# Enabled features (will be populated by command line args)
declare -a ENABLED_FEATURES=()

###############################################################################
# Help Functions                                                               #
###############################################################################

show_help() {
    local help_template="$SCRIPT_DIR/templates/help.txt.template"
    if [[ -f "$help_template" ]]; then
        local help_text
        help_text=$(cat "$help_template")
        help_text=${help_text//%VERSION%/$VERSION}
        help_text=${help_text//%SCRIPT_NAME%/$SCRIPT_NAME}
        echo "$help_text"
    else
        print_error "Help template not found: $help_template"
        exit 1
    fi
}

list_modules() {
    print_status "Available modules:"
    for module in "${!AVAILABLE_MODULES[@]}"; do
        printf "  %b%-15s%b %s\n" "${CYAN}" "$module" "${NC}" "${AVAILABLE_MODULES[$module]}"
    done
}

###############################################################################
# Main Functions                                                               #
###############################################################################

load_module() {
    local module="$1"
    local module_file="$SCRIPT_DIR/modules/${module}.sh"

    if [[ -f "$module_file" ]]; then
        source "$module_file"
    else
        print_error "Module not found: $module"
        exit 1
    fi
}

apply_settings() {
    local no_restart="$1"

    # Load enabled modules
    for feature in "${ENABLED_FEATURES[@]}"; do
        load_module "$feature"
    done

    # Always run backup first if enabled
    if [[ " ${ENABLED_FEATURES[*]} " =~ " backup " ]]; then
        setup_backup
    fi

    # Apply settings for each enabled module (except backup)
    for feature in "${ENABLED_FEATURES[@]}"; do
        if [[ "$feature" != "backup" ]] && type "setup_${feature}" &>/dev/null; then
            "setup_${feature}"
        fi
    done

    # Run cleanup for each module
    if [[ "$no_restart" != "true" ]]; then
        for feature in "${ENABLED_FEATURES[@]}"; do
            if type "setup_${feature}_cleanup" &>/dev/null; then
                "setup_${feature}_cleanup"
            fi
        done
    fi
}

###############################################################################
# Main Execution                                                               #
###############################################################################

main() {
    local no_restart="false"

    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                echo "$VERSION"
                exit 0
                ;;
            -l|--list)
                list_modules
                exit 0
                ;;
            -a|--all)
                ENABLED_FEATURES=("${!AVAILABLE_MODULES[@]}")
                ;;
            --no-restart)
                no_restart="true"
                ;;
            --*)
                module="${1#--}"
                if [[ -n "${AVAILABLE_MODULES[$module]:-}" ]]; then
                    ENABLED_FEATURES+=("$module")
                else
                    print_error "Unknown module: $module"
                    exit 1
                fi
                ;;
            *)
                print_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
        shift
    done

    # If no modules specified, enable all
    if [[ ${#ENABLED_FEATURES[@]} -eq 0 ]]; then
        ENABLED_FEATURES=("${!AVAILABLE_MODULES[@]}")
    fi

    # Check for root privileges
    ensure_sudo
    keep_sudo_alive

    # Apply settings
    apply_settings "$no_restart"

    print_success "Configuration complete!"
    if [[ "$no_restart" != "true" ]]; then
        print_warning "Some changes may require a logout/restart to take effect."
    fi
}

# Execute main function with all arguments
main "$@"