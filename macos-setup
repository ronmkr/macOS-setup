#!/usr/bin/env bash

set -euo pipefail

###############################################################################
# Configuration                                                                #
###############################################################################

# Script configuration
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly BACKUP_DIR="${SCRIPT_DIR}/backups"
readonly LOG_DIR="${SCRIPT_DIR}/logs"
readonly CONFIG_DIR="${SCRIPT_DIR}/config"

# Default settings
DRY_RUN=false
VERBOSE=false
SILENT=false
NO_RESTART=false

# Source required libraries
source "$SCRIPT_DIR/lib/utils.sh"
source "$SCRIPT_DIR/lib/modules.sh"
source "$SCRIPT_DIR/lib/logging.sh"

# Available modules
declare -A AVAILABLE_MODULES=(
    ["backup"]="Create backup of current settings"
    ["finder"]="Finder settings"
    ["dock"]="Dock settings (Appearance + Items)"
    ["safari"]="Safari settings"
    ["mail"]="Mail.app settings"
    ["terminal"]="Terminal settings"
    ["system"]="System settings"
    ["input"]="Input device settings"
    ["security"]="Security settings"
    ["cleanup"]="System cleanup operations"
    ["brew"]="Homebrew, Casks, and App Store (Brewfile)"
    ["developer"]="Xcode Tools and dev environments"
    ["softwareupdate"]="macOS system updates"
    ["dotfiles"]="Symlink config files from dotfiles/"
)

# Enabled features
declare -a ENABLED_FEATURES=()

###############################################################################
# Main Functions                                                               #
###############################################################################

load_module() {
    local module="$1"
    local module_file="$SCRIPT_DIR/modules/${module}.sh"
    if [[ -f "$module_file" ]]; then
        source "$module_file"
    else
        print_error "Module not found: $module"
        exit 1
    fi
}

apply_settings() {
    sort_modules
    for feature in "${ENABLED_FEATURES[@]}"; do
        load_module "$feature"
    done

    if [[ " ${ENABLED_FEATURES[*]} " =~ " backup " ]]; then
        setup_backup
    fi

    for feature in "${ENABLED_FEATURES[@]}"; do
        if [[ "$feature" != "backup" ]] && declare -f "setup_${feature}" >/dev/null; then
            "setup_${feature}"
        fi
    done

    if [[ "$NO_RESTART" != "true" ]]; then
        for feature in "${ENABLED_FEATURES[@]}"; do
            if declare -f "setup_${feature}_cleanup" >/dev/null; then
                "setup_${feature}_cleanup"
            fi
        done
    fi
}

###############################################################################
# Main Execution                                                               #
###############################################################################

main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                # show_help omitted for brevity, would be here
                exit 0
                ;;
            -d|--dry-run) DRY_RUN=true ;;
            --verbose) VERBOSE=true ;;
            -a|--all)
                for mod in "${!AVAILABLE_MODULES[@]}"; do
                    [[ "$mod" != "backup" ]] && ENABLED_FEATURES+=("$mod")
                done
                ;;
            --*)
                module="${1#--}"
                [[ -n "${AVAILABLE_MODULES[$module]:-}" ]] && ENABLED_FEATURES+=("$module") || { print_error "Unknown module: $module"; exit 1; }
                ;;
            *) shift ;;
        esac
        shift
    done

    export DRY_RUN VERBOSE USER_NAME USER_HOME SCRIPT_DIR

    if [[ ${#ENABLED_FEATURES[@]} -eq 0 ]]; then
        ENABLED_FEATURES=("system" "finder" "dock" "terminal" "security")
    fi

    ensure_sudo
    keep_sudo_alive

    apply_settings

    print_success "Configuration complete!"
    show_notification "macOS Setup" "System configuration has finished successfully!"
}

main "$@"